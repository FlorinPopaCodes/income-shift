#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.10"
# dependencies = [
#     "ipumspy",
#     "pandas",
#     "numpy",
#     "pyarrow",
# ]
# ///
"""
Process IPUMS CPS ASEC microdata into income distribution JSON for Remotion.

Methodology:
  - Unit: adults (age 18+), weighted by ASECWT except YEAR=2020 uses ASECWTCVD
  - Size-adjust: income / sqrt(household_size) * sqrt(3)
  - Deflate to 2024 constant dollars (R-CPI-U-RS / C-CPI-U hybrid)
  - Floor negative real incomes at $0 for histogram + summary stats
  - Density: % per $1k (bar area = population share)
  - Middle-income band: 2/3 to 2x weighted median

Data source:
  Sarah Flood et al. IPUMS CPS: Version 13.0 [dataset].
  Minneapolis, MN: IPUMS, 2025. https://doi.org/10.18128/D030.V13.0

Usage:
  ./process                  # reads from ipums_extract/
  ./process --output data.json
"""

import json
import argparse
import sys
import numpy as np
from pathlib import Path

EXTRACT_DIR = Path("ipums_extract")
DEFAULT_OUTPUT = "video/src/data.json"
TARGET_HHSIZE = 3.0

# Census Bureau's price index for deflating income, base Dec 1999 = 100.
# Hybrid series matching Census P-60 reports:
#   1967-1977: CPI-U-X1 (experimental, rental equivalence)
#   1978-1999: R-CPI-U-RS (BLS research series)
#   2000-2022: C-CPI-U (chained CPI, final/revised)
#
# 1967-2022: Census Table P-60/279
# 2023-2024: estimated from FRED C-CPI-U (series SUUR0000SA0)
CPI_INDEX = {
    1967: 22.7, 1968: 23.6, 1969: 24.6, 1970: 25.8, 1971: 26.9,
    1972: 27.8, 1973: 29.5, 1974: 32.4, 1975: 35.1, 1976: 37.1,
    1977: 39.5, 1978: 42.2, 1979: 46.2, 1980: 51.3, 1981: 56.2,
    1982: 59.6, 1983: 62.1, 1984: 64.7, 1985: 66.9, 1986: 68.0,
    1987: 70.3, 1988: 72.9, 1989: 76.1, 1990: 79.8, 1991: 82.7,
    1992: 84.8, 1993: 86.9, 1994: 88.8, 1995: 90.9, 1996: 93.3,
    1997: 95.3, 1998: 96.6, 1999: 98.6, 2000: 102.0, 2001: 104.3,
    2002: 105.6, 2003: 107.8, 2004: 110.5, 2005: 113.7, 2006: 117.0,
    2007: 120.0, 2008: 124.4, 2009: 123.9, 2010: 125.6, 2011: 129.5,
    2012: 132.0, 2013: 133.6, 2014: 135.5, 2015: 135.4, 2016: 136.6,
    2017: 139.0, 2018: 141.8, 2019: 143.9, 2020: 145.4, 2021: 152.0,
    2022: 163.9,
    2023: 170.0, 2024: 174.4,
}
BASE_YEAR = 2024
DEFLATOR_BASE = CPI_INDEX[BASE_YEAR]

# Bin edges: 3 zones + small zone 4 + overflow
# Zone 1: $0-70k     (14 bins x $5k)
# Zone 2: $70k-140k  (14 bins x $5k)
# Zone 3: $140k-280k (14 bins x $10k)
# Zone 4: $280k-500k (11 bins x $20k)
# Overflow: $500k+    (1 bin, notional $500k)
BIN_EDGES = np.array(
    list(range(0, 70_001, 5_000))            # 0, 5k, ..., 70k  (15 edges)
    + list(range(75_000, 140_001, 5_000))    # 75k, ..., 140k   (14 edges)
    + list(range(150_000, 280_001, 10_000))  # 150k, ..., 280k  (14 edges)
    + list(range(300_000, 500_001, 20_000)),  # 300k, ..., 500k  (11 edges)
    dtype=np.float64,
)
N_EDGES = len(BIN_EDGES)  # 54 edges -> 53 bounded bins + 1 overflow = 54 bins
N_BINS = N_EDGES  # 54 total (53 bounded + 1 overflow)

# Bin widths in $k for density
BIN_WIDTHS_K = []
for i in range(N_EDGES - 1):
    BIN_WIDTHS_K.append((BIN_EDGES[i + 1] - BIN_EDGES[i]) / 1000)
BIN_WIDTHS_K.append(500.0)  # $500k+ notional width


def weighted_median(values, weights):
    order = np.argsort(values)
    sorted_v = values[order]
    sorted_w = weights[order]
    cum_w = np.cumsum(sorted_w)
    idx = np.searchsorted(cum_w, cum_w[-1] / 2)
    return sorted_v[min(idx, len(sorted_v) - 1)]


def load_extract():
    import pandas as pd

    cache = EXTRACT_DIR / "cached.parquet"
    if cache.exists():
        dat_files = list(EXTRACT_DIR.glob("*.dat.gz"))
        if dat_files and cache.stat().st_mtime >= dat_files[0].stat().st_mtime:
            print(f"Reading {cache} (cached)...")
            df = pd.read_parquet(cache)
            print(f"  {len(df):,} person records, {df['YEAR'].nunique()} survey years")
            return df

    from ipumspy import readers

    ddi_file = list(EXTRACT_DIR.glob("*.xml"))[0]
    dat_file = list(EXTRACT_DIR.glob("*.dat.gz"))[0]
    print(f"Reading {dat_file} (first run, caching to parquet)...")
    ddi = readers.read_ipums_ddi(ddi_file)
    df = readers.read_microdata(ddi, dat_file)
    df.to_parquet(cache)
    print(f"  Cached to {cache}")
    print(f"  {len(df):,} person records, {df['YEAR'].nunique()} survey years")
    return df


def choose_person_weights(adults):
    weights = adults["ASECWT"].values.astype(float).copy()
    covid_mask = adults["YEAR"].values == 2020

    if not covid_mask.any():
        return weights

    if "ASECWTCVD" not in adults.columns:
        print(
            "Warning: ASECWTCVD is missing from the extract; using ASECWT for YEAR=2020.",
            file=sys.stderr,
        )
        return weights

    covid_weights = adults["ASECWTCVD"].values.astype(float)
    available_mask = covid_mask & ~np.isnan(covid_weights)

    if not available_mask.any():
        print(
            "Warning: ASECWTCVD is empty for YEAR=2020; using ASECWT for that survey year.",
            file=sys.stderr,
        )
        return weights

    weights[available_mask] = covid_weights[available_mask]

    missing_count = int(covid_mask.sum() - available_mask.sum())
    if missing_count:
        print(
            f"Warning: ASECWTCVD missing on {missing_count:,} YEAR=2020 adult records; "
            "falling back to ASECWT for those cases.",
            file=sys.stderr,
        )

    return weights


def process(df):
    # Filter adults 18+
    adults = df[df["AGE"] >= 18].copy()
    print(f"\nAdults (18+): {len(adults):,} records")

    # Exclude NIU (Not in Universe) for HHINCOME
    adults = adults[adults["HHINCOME"] < 99999999].copy()
    print(f"After income filter: {len(adults):,} records")

    # 2014 ASEC redesign: keep only the redesigned income-question subsample
    # (HFLAG=1). This avoids mixing incompatible income questionnaires in the
    # point labeled 2013.
    redesign_mask = (adults["YEAR"] == 2014) & (adults["HFLAG"] == 0)
    adults = adults[~redesign_mask].copy()
    print(f"After HFLAG filter: {len(adults):,} records")

    # Income year = survey year - 1 (ASEC conducted in March, reports prior year)
    adults["INCOME_YEAR"] = adults["YEAR"] - 1
    adults["PERSON_WEIGHT"] = choose_person_weights(adults)

    # Compute weighted median household size per income year
    # Use household-level records (PERNUM==1) with household weight
    hh_records = adults[adults["PERNUM"] == 1].copy()
    median_hhsize_by_year = {}
    for iy in sorted(hh_records["INCOME_YEAR"].unique()):
        mask = hh_records["INCOME_YEAR"] == iy
        sizes = hh_records.loc[mask, "NUMPREC"].values.astype(float)
        wts = hh_records.loc[mask, "ASECWTH"].values.astype(float)
        median_hhsize_by_year[iy] = float(weighted_median(sizes, wts))

    print(f"\nMedian household size range: "
          f"{min(median_hhsize_by_year.values()):.2f} - "
          f"{max(median_hhsize_by_year.values()):.2f}")

    # Size-adjust income to a fixed 3-person household, following Pew.
    income_years = adults["INCOME_YEAR"].values
    hhsizes = adults["NUMPREC"].values.astype(float)
    raw_income = adults["HHINCOME"].values.astype(float)

    adjusted_income = raw_income / np.sqrt(hhsizes) * np.sqrt(TARGET_HHSIZE)

    # Deflate to 2024 constant dollars, then floor negatives at zero so the
    # histogram, median, mean, and middle-income thresholds all use one rule.
    deflators = np.array([DEFLATOR_BASE / CPI_INDEX.get(y, DEFLATOR_BASE)
                          for y in income_years])
    real_income = np.maximum(adjusted_income * deflators, 0.0)
    adults["REAL_INCOME"] = real_income

    # Process each year
    results = []

    for income_year in sorted(adults["INCOME_YEAR"].unique()):
        if income_year < 1971 or income_year > 2024:
            continue

        mask = income_years == income_year
        incomes = real_income[mask]
        weights = adults["PERSON_WEIGHT"].values[mask]
        total_weight = weights.sum()

        if total_weight == 0:
            continue

        # Weighted median and mean of size-adjusted real income
        w_median = weighted_median(incomes, weights)
        w_mean = float(np.dot(incomes, weights) / total_weight)

        # Middle-income band
        mid_low = w_median * 2 / 3
        mid_high = w_median * 2

        # Bin into histogram
        bin_idx = np.searchsorted(BIN_EDGES, incomes, side="right") - 1
        bin_idx = np.clip(bin_idx, 0, N_BINS - 1)

        # Compute density: % per $1k
        bars = []
        for i in range(N_BINS):
            pct = float(weights[bin_idx == i].sum() / total_weight * 100)
            bars.append(round(pct / BIN_WIDTHS_K[i], 4))

        total_adults_k = round(float(total_weight) / 1000)

        results.append({
            "y": int(income_year),
            "b": bars,
            "m": round(float(w_median)),
            "n": round(float(w_mean)),
            "h": total_adults_k,
            "ml": round(float(mid_low)),
            "mu": round(float(mid_high)),
            "hs": round(median_hhsize_by_year[income_year], 2),
        })

        # Validation: sum(density * width) should ~ 100%
        area = sum(bars[i] * BIN_WIDTHS_K[i] for i in range(N_BINS))
        print(f"  {income_year}: median=${w_median:>8,.0f}  "
              f"middle=${mid_low:>7,.0f}-${mid_high:>8,.0f}  "
              f"adults={total_adults_k:>5,}k  hhsize={median_hhsize_by_year[income_year]:.1f}  "
              f"area={area:.1f}%")

    return results


def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--output", "-o", default=DEFAULT_OUTPUT)
    args = parser.parse_args()

    df = load_extract()
    results = process(df)

    output_path = Path(args.output)
    output_path.parent.mkdir(parents=True, exist_ok=True)

    output = {
        "bin_widths_k": [float(w) for w in BIN_WIDTHS_K],
        "years": results,
    }

    with open(output_path, "w") as f:
        json.dump(output, f, separators=(",", ":"))

    size_kb = output_path.stat().st_size / 1024
    print(f"\nSaved {len(results)} years ({results[0]['y']}-{results[-1]['y']}) "
          f"to {output_path} ({size_kb:.0f}KB)")
    print(f"Bins per year: {len(results[0]['b'])}")


if __name__ == "__main__":
    main()
